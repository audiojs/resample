{
  "name": "@audio/resample",
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "description": "Sample-rate conversion \u2014 umbrella for @audio/resample-* atoms (sinc, linear, polyphase)",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "audio",
    "dsp",
    "resample",
    "sample-rate-conversion",
    "src"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "node test.js",
